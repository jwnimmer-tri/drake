[lcm] Add Drake-specific compiler flags

--- lcm-bazel/private/copts.bzl
+++ lcm-bazel/private/copts.bzl
@@ -6,5 +6,9 @@ WARNINGS_COPTS = select({
         "-Wno-unused-parameter",
         "-Wno-format-zero-length",
         "-Wno-stringop-truncation",
+        # Additional Drake-specific options.
+        "-w",
+        "-std=gnu11",
+        "-fvisibility=hidden",
     ],
 })
