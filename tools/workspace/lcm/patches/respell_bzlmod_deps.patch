[lcm] Respell LCM's external dependencies

The spellings used upstream expect LCM to be consumed via bzlmod.
In Drake, for now we're still pulling in LCM with a repository rule,
so we need to respell the labels to match Drake's current convention.

On 2025-09-01 when we drop support for WORKSPACE we should also delete
this patch.

Reasoning for not upstreaming this patch: temporary Drake-specific
build requirement.

--- lcm/BUILD.bazel
+++ lcm/BUILD.bazel
@@ -143,7 +143,7 @@ LINKOPTS = select({
 
 DEPS = [
     ":_public_hdrs",
-    "@glib//glib",
+    "@glib",
 ]
 
 cc_library(

--- lcmgen/BUILD.bazel
+++ lcmgen/BUILD.bazel
@@ -28,6 +28,6 @@ cc_binary(
     visibility = ["//visibility:public"],
     deps = [
         "//lcm:lcm-version",
-        "@glib//glib",
+        "@glib",
     ],
 )

--- lcm-java/BUILD.bazel
+++ lcm-java/BUILD.bazel
@@ -48,7 +48,7 @@ java_library(
     ],
     visibility = ["//visibility:public"],
     deps = [
-        "@lcm_maven//:net_sf_jchart2d_jchart2d",
+        "@net_sf_jchart2d//jar",
     ],
 )
 
